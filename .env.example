# ═══════════════════════════════════════════════════════════════════════════
# Environment Variables - Copy this to .env.local
# ═══════════════════════════════════════════════════════════════════════════

# SUPABASE CONFIGURATION (when you're ready to connect to database)
# Get these from your Supabase project settings
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# DATABASE URL (if using different provider)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# NODE ENVIRONMENT
# NODE_ENV=development

# API CONFIGURATION
# NEXT_PUBLIC_API_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════════════════════
# INSTRUCTIONS:
# ═══════════════════════════════════════════════════════════════════════════
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in your values from Supabase (or other services)
# 3. Never commit .env.local to git
# 4. Keep this .env.example file in git for reference
# ═══════════════════════════════════════════════════════════════════════════
